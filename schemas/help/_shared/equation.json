{
  "$schema": "../_schema.json",
  "element": "equation",
  "shared_base": true,
  "properties": {
    "formula": {
      "type": "string",
      "description": "math expression. Aliases: text.",
      "aliases": [
        "text"
      ],
      "add": true,
      "set": true,
      "get": true,
      "examples": [
        "--prop formula=\"x^2 + y^2 = z^2\""
      ],
      "readback": "LaTeX expression reconstructed from the OOXML <m:oMath> tree; used by pptx batch replay to round-trip the equation.",
      "enforcement": "report"
    }
  }
}
